PORT=5000

# Supabase project settings — Settings > API Keys in the Supabase dashboard.
# Use the "secret" key here (server-side only), never the publishable key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-secret-key

# Google Gemini API key (currently unused by the codebase, reserved for
# future LLM-backed evaluation).
GEMINI_API_KEY=your-gemini-api-key

# Optional — real Langfuse project keys. If omitted, the app falls back to
# mock keys and tracing calls will silently no-op against a fake project.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
